    <%- include('../public/header.ejs') -%>
    <div class="container-fluid">
        <div class="row">
            <%- include('../public/aslideleft.ejs') -%>
            <div class="col-sm-10">
                <ol class="breadcrumb">
                    <li class="active">用户管理</li>
                    <li class="active">用户编辑</li>
                </ol>
                <div class="panel panel-default">
                    <div class="panel-heading">用户添加</div>
                    <div class="panel-body">
                        <div class="table-responsive input-form">
                            <form action="/admin/user/doEdit" method="post">
                                <ul>
                                    <li><input type="hidden" value="<%= list._id %>" name="_id"/></li>
                                    <li>用户名: <input type="text" name="username" value="<%= list.username %>" /></li>
                                    <li>密码: <input type="password" name="password" /></li>
                                    <li>确认密码: <input type="password" name="checkpassword" /></li>
                                    <li><br/><button type="submit" class="btn btn-default">提交</button></li>
                                </ul>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>